	partition 'public sales' = m
		mode: import
		source =
				let
				    Fonte = PostgreSQL.Database("localhost", "game_market_intelligence"),
				    public_sales = Fonte{[Schema="public",Item="sales"]}[Data]
				in
				    public_sales

	annotation PBI_ResultType = Table

